# MISC
# ═══════════════════════════════════════════════════════════════

# Minimum trade amount (to avoid tiny fractional trades)
MIN_TRADE_VALUE_INR = 5_000     # ₹5,000 minimum trade size
MIN_TRADE_VALUE_USD = 100       # $100 minimum trade size

# Historical data period for ML training
ML_TRAINING_PERIOD = "5y"       # 5 years of historical data
ML_INFERENCE_PERIOD = "3mo"     # 3 months for recent inference features

# Agent timeout settings (seconds)
AGENT_TIMEOUT_SECONDS: Dict[str, int] = {
    "PriceAgent": 30,
    "NewsAgent": 45,
    "MacroAgent": 60,
    "EarningsAgent": 45,
    "TechnicalAgent": 30,
    "FundamentalAgent": 30,
    "SentimentAgent": 120,       # Longer due to multiple Groq API calls
    "MLPredictionAgent": 60,
    "EventRiskAgent": 30,
    "PositionSizingAgent": 15,
    "PortfolioRiskAgent": 15,
    "DecisionAgent": 60,
    "ExecutionAgent": 30,
}

# Database connection pool settings
DB_POOL_SIZE = 5
DB_MAX_OVERFLOW = 10
DB_POOL_TIMEOUT = 30

# Logging format
LOG_FORMAT = "%(asctime)s | %(levelname)-8s | %(name)s | %(message)s"
LOG_DATE_FORMAT = "%Y-%m-%d %H:%M:%S"

# ========================================
# ENSEMBLE MODEL PARAMETERS
# ========================================
ENSEMBLE_LSTM_WEIGHT = 0.5  # Weight for LSTM predictions (50%)
ENSEMBLE_XGBOOST_WEIGHT = 0.5  # Weight for XGBoost predictions (50%)
ENSEMBLE_MIN_AGREEMENT = 0.6  # Models must agree within 60% to avoid HOLD
ENSEMBLE_BUY_THRESHOLD = 0.65  # Already exists above, but keep for ensemble
ENSEMBLE_SELL_THRESHOLD = 0.35  # Already exists above

