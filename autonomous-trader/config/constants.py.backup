# ═══════════════════════════════════════════════════════════════
# MARKET TRADING HOURS
# ═══════════════════════════════════════════════════════════════

class MarketHours:
    """Defines when a market is open for trading."""

    def __init__(
        self,
        name: str,
        timezone: pytz.BaseTzInfo,
        open_time: time,
        close_time: time,
        pre_open_time: time,   # Data warmup start (before actual trading)
        pre_close_time: time,  # Last safe time to open new positions
    ):
        self.name = name
        self.timezone = timezone
        self.open_time = open_time
        self.close_time = close_time
        self.pre_open_time = pre_open_time
        self.pre_close_time = pre_close_time


# NSE (National Stock Exchange, India)
# Regular session: 9:15 AM – 3:30 PM IST, Monday–Friday
NSE_HOURS = MarketHours(
    name="NSE",
    timezone=TZ_INDIA,
    open_time=time(9, 15),
    close_time=time(15, 30),
    pre_open_time=time(8, 45),   # Data warmup at 8:45 AM IST
    pre_close_time=time(15, 0),  # No new positions after 3:00 PM IST
)

# NYSE / NASDAQ (United States)
# Regular session: 9:30 AM – 4:00 PM ET, Monday–Friday
NYSE_HOURS = MarketHours(
    name="NYSE",
    timezone=TZ_US_EAST,
    open_time=time(9, 30),
    close_time=time(16, 0),
    pre_open_time=time(9, 0),    # Data warmup at 9:00 AM ET
    pre_close_time=time(15, 30), # No new positions after 3:30 PM ET
)


