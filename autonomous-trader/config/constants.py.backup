"""
config/constants.py
===================
Static constants used across the system:
  - Market trading hours
  - Market holidays (NSE + NYSE, 2025-2026)
  - Default stock watchlists
  - Market regime definitions
  - Score thresholds

These values do not change at runtime. All configurable values
(e.g., watchlist override, risk limits) live in settings.py instead.
"""

from datetime import date, time
from enum import Enum
from typing import Dict, List, Set
import pytz

