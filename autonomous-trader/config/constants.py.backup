# ═══════════════════════════════════════════════════════════════
# FRED (Federal Reserve) ECONOMIC DATA SERIES IDs
# ═══════════════════════════════════════════════════════════════
# These are used by MacroCollector to assess economic conditions.
# All are free to access via the FRED API (no key required).

FRED_SERIES: Dict[str, str] = {
    "federal_funds_rate": "FEDFUNDS",          # US interest rate target
    "gdp_growth": "A191RL1Q225SBEA",           # US real GDP growth rate (%)
    "unemployment": "UNRATE",                   # US unemployment rate (%)
    "cpi_inflation": "CPIAUCSL",               # US consumer price index
    "treasury_10y": "DGS10",                   # 10-year Treasury yield (%)
    "treasury_2y": "DGS2",                     # 2-year Treasury yield (%)
    "yield_curve": "T10Y2Y",                   # 10Y minus 2Y spread (recession signal)
    "consumer_sentiment": "UMCSENT",            # University of Michigan consumer sentiment
    "industrial_production": "INDPRO",          # US industrial production index
}


