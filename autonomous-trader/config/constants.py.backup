# ═══════════════════════════════════════════════════════════════
# MARKET REGIME
# ═══════════════════════════════════════════════════════════════

class MarketRegime(str, Enum):
    """
    Current overall market condition.
    Determined by MacroCollector based on VIX, moving averages, and macro data.
    Affects position sizing — the worse the regime, the smaller the positions.
    """
    STRONG_BULL = "STRONG_BULL"   # Above 200MA, VIX < 15, economy growing
    BULL = "BULL"                  # Above 200MA, VIX 15-20
    NEUTRAL = "NEUTRAL"            # Mixed signals, VIX 20-25
    BEAR = "BEAR"                  # Below 200MA, VIX 25-35
    STRONG_BEAR = "STRONG_BEAR"   # Below 200MA, VIX > 35, recession signals

# Position sizing multiplier per market regime
# Final position size = base_size × regime_multiplier
REGIME_POSITION_MULTIPLIER: Dict[str, float] = {
    MarketRegime.STRONG_BULL: 1.0,   # Full position allowed
    MarketRegime.BULL: 0.8,          # 80% of normal position
    MarketRegime.NEUTRAL: 0.6,       # 60% of normal position
    MarketRegime.BEAR: 0.4,          # 40% of normal position
    MarketRegime.STRONG_BEAR: 0.0,   # No new positions (preserve capital)
}

# VIX thresholds for regime determination
VIX_LOW = 15.0       # Below this = calm market
VIX_MODERATE = 20.0  # 15-20 = slightly elevated
VIX_HIGH = 25.0      # 20-25 = elevated uncertainty
VIX_VERY_HIGH = 35.0 # 25-35 = fearful market
VIX_EXTREME = 40.0   # Above 40 = circuit breaker territory (extreme fear)


# ═══════════════════════════════════════════════════════════════
# TECHNICAL ANALYSIS THRESHOLDS
# ═══════════════════════════════════════════════════════════════

# RSI (Relative Strength Index) — measures momentum (0-100)
RSI_OVERSOLD = 30     # Below this: potentially oversold, consider buying
RSI_OVERBOUGHT = 70   # Above this: potentially overbought, consider selling
RSI_LOWER_NEUTRAL = 45
RSI_UPPER_NEUTRAL = 55

# Bollinger Bands position (0 = at lower band, 1 = at upper band)
BB_LOWER_ZONE = 0.20  # Price near lower band — potential bounce
BB_UPPER_ZONE = 0.80  # Price near upper band — potential reversal

# Volume surge threshold
VOLUME_SURGE_STRONG = 2.0    # 2x average volume = strong conviction
VOLUME_SURGE_MODERATE = 1.5  # 1.5x average volume = moderate conviction

# Price proximity thresholds (as % of price)
PRICE_AT_LEVEL_THRESHOLD = 0.02   # Within 2% = "at" a support/resistance level
NEAR_SUPPORT_THRESHOLD = 0.02     # Within 2% of support
NEAR_RESISTANCE_THRESHOLD = 0.02  # Within 2% of resistance

# SMA proximity
SMA200_AT_THRESHOLD = 0.02  # Within 2% of SMA200 = "at key level"

# ATR multipliers for stop loss and take profit
STOP_LOSS_ATR_MULTIPLE = 2.0    # Stop loss = entry - (2 × ATR)
TAKE_PROFIT_ATR_MULTIPLE = 3.0  # Take profit = entry + (3 × ATR) → 1:1.5 R/R


# ═══════════════════════════════════════════════════════════════
# FUNDAMENTAL ANALYSIS THRESHOLDS
# ═══════════════════════════════════════════════════════════════

# Scoring criteria — each criterion adds 2 points to fundamental_score (max 10)
FUNDAMENTAL_PE_MAX = 25.0              # PE ratio below this = reasonably valued
FUNDAMENTAL_DEBT_EQUITY_MAX = 1.0     # Debt/Equity below this = conservatively financed
FUNDAMENTAL_REVENUE_GROWTH_MIN = 10.0 # YoY revenue growth above this = healthy growth (%)
FUNDAMENTAL_PROFIT_MARGIN_MIN = 15.0  # Net profit margin above this = efficient (%)
FUNDAMENTAL_ROE_MIN = 15.0            # Return on Equity above this = good capital use (%)
FUNDAMENTAL_MIN_METRICS = 3           # Minimum number of metrics needed for a valid score


# ═══════════════════════════════════════════════════════════════
# DATA VALIDATION THRESHOLDS
# ═══════════════════════════════════════════════════════════════

# Price data freshness — how old can data be before it's considered stale?
PRICE_MAX_AGE_MINUTES = 15        # During market hours
PRICE_MAX_AGE_EOD_MINUTES = 60    # At market close / pre-market

# Suspicious price change threshold
PRICE_SPIKE_THRESHOLD = 0.20      # >20% intraday move is suspicious (may be bad data)

# Minimum trading volume for a stock to be liquid enough to trade
MIN_DAILY_VOLUME = 100_000        # 1 lakh shares/day minimum for India
MIN_DAILY_VOLUME_US = 500_000     # 5 lakh shares/day for US stocks

# Historical data requirements
MIN_TRADING_DAYS_HISTORY = 252    # 1 year of data required for ML models
MAX_CONSECUTIVE_MISSING_DAYS = 5  # More than 5 missing days in a row = data problem

# News data
MIN_NEWS_ARTICLES = 1             # Warn if fewer than this in last 48 hours
MIN_NEWS_ARTICLES_FOR_SENTIMENT = 3  # Need at least 3 articles for reliable sentiment


# ═══════════════════════════════════════════════════════════════
# EARNINGS RISK LEVELS
# ═══════════════════════════════════════════════════════════════

class EarningsRiskLevel(str, Enum):
    """
    Risk level based on proximity to an earnings announcement.
    Stocks become very unpredictable around earnings — reduce or block trades.
    """
    NONE = "NONE"       # No earnings in 7+ days — trade normally
    LOW = "LOW"         # 3-7 days — trade with reduced position (70% normal)
    HIGH = "HIGH"       # 1-3 days (72 hrs) — trade with half position (50% normal)
    BLOCK = "BLOCK"     # Within 24 hours — DO NOT trade this stock

EARNINGS_BLOCK_HOURS = 24    # Block trades if earnings within 24 hours
EARNINGS_HIGH_RISK_HOURS = 72   # High risk if earnings within 72 hours
EARNINGS_LOW_RISK_DAYS = 7      # Low risk if earnings within 7 days


# ═══════════════════════════════════════════════════════════════
# CIRCUIT BREAKER THRESHOLDS
# ═══════════════════════════════════════════════════════════════

CIRCUIT_BREAKER_CONSECUTIVE_LOSSES = 5      # 5 losses in a row → halt
CIRCUIT_BREAKER_RUNAWAY_ORDERS = 20         # 20+ orders in 10 minutes → halt
CIRCUIT_BREAKER_DATA_FEED_TIMEOUT_MINS = 30 # No price data for 30 mins → halt
CIRCUIT_BREAKER_BROKER_TIMEOUT_MINS = 15    # No broker response for 15 mins → halt
CIRCUIT_BREAKER_VIX_THRESHOLD = 40.0        # VIX above 40 → halt


